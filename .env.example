# Application
APP_NAME=OffGrid API
APP_ENV=development
APP_DEBUG=false
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+psycopg://offgrid:offgrid@localhost:5432/offgrid

# Redis / Queue
REDIS_URL=redis://localhost:6379/0

# JWT Security
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Request safety
REQUEST_BODY_MAX_BYTES=1000000

# AI Providers
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key

# Social/Marketing Integrations
INSTAGRAM_API_BASE_URL=https://graph.instagram.com
INSTAGRAM_ACCESS_TOKEN=
LINKEDIN_API_BASE_URL=https://api.linkedin.com
LINKEDIN_ACCESS_TOKEN=
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_ANALYTICS_CREDENTIALS_JSON=
GOOGLE_SEARCH_CONSOLE_SITE_URL=
GOOGLE_SEARCH_CONSOLE_CREDENTIALS_JSON=
PAGESPEED_API_KEY=your-pagespeed-api-key

# Alerts and Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
